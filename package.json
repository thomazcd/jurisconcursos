{
    "name": "juris-concursos",
    "version": "2.1.56",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "rm -rf .next && next build",
        "start": "next start",
        "lint": "next lint",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
        "db:studio": "prisma studio",
        "setup": "npm install && prisma generate && prisma db push && npm run db:seed",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.7.2",
        "@google/genai": "^1.43.0",
        "@prisma/client": "^5.22.0",
        "@vercel/analytics": "^1.6.1",
        "bcryptjs": "^2.4.3",
        "multer": "^2.1.0",
        "next": "14.2.5",
        "next-auth": "^4.24.11",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "recharts": "^3.7.0",
        "resend": "^6.9.3",
        "swr": "^2.4.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.17.9",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "prisma": "^5.22.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2"
    }
}